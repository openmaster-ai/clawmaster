{
  "name": "openclaw-manager",
  "version": "0.2.3",
  "private": true,
  "description": "龙虾管家 - OpenClaw 图形化管理工具",
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@openclaw-manager/web",
    "dev:web": "npm run dev --workspace=@openclaw-manager/backend & npm run dev --workspace=@openclaw-manager/web",
    "dev:backend": "npm run dev --workspace=@openclaw-manager/backend",
    "build": "npm run build --workspace=@openclaw-manager/web",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "lint": "npm run lint --workspace=@openclaw-manager/web",
    "format": "npm run format --workspace=@openclaw-manager/web",
    "format:check": "npm run format:check --workspace=@openclaw-manager/web"
  },
  "keywords": [
    "openclaw",
    "desktop",
    "manager",
    "tauri"
  ],
  "author": "OpenClaw Team",
  "license": "MIT",
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1"
  }
}
